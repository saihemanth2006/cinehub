<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- CineHub Launch Theme (Night) — identical to day since CineHub is always dark -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:navigationBarColor">#FF111118</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Normal Theme (Night) -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/cinehub_background</item>
        <item name="android:navigationBarColor">#FF111118</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <color name="cinehub_background">#FF08080D</color>
    <color name="cinehub_surface">#FF111118</color>
    <color name="cinehub_primary">#FF8B5CF6</color>
</resources>
