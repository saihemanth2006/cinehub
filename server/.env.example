# ─────────────────────────────────────────────
# CineHub AI — Environment Configuration
# ─────────────────────────────────────────────

# ── Application ──────────────────────────────
NODE_ENV=development
PORT=5000
API_PREFIX=/api
APP_NAME=CineHub
APP_URL=http://localhost:5000
CLIENT_URL=http://localhost:3000

# ── Database ─────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/cinehub_dev
MONGODB_URI_TEST=mongodb://localhost:27017/cinehub_test

# ── Redis ────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── JWT Authentication ───────────────────────
JWT_ACCESS_SECRET=your_access_secret_key_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_key_here_min_32_chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_RESET_PASSWORD_EXPIRATION=10m
JWT_VERIFY_EMAIL_EXPIRATION=24h

# ── Bcrypt ───────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ── Rate Limiting ────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── AI Services ──────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4-turbo
OPENAI_MAX_TOKENS=4096

GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-1.5-pro

AI_DEFAULT_PROVIDER=openai

# ── AWS S3 / Storage ────────────────────────
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=cinehub-media
STORAGE_PROVIDER=local

# ── Email (SMTP) ─────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=CineHub <noreply@cinehub.ai>

# ── Logging ──────────────────────────────────
LOG_LEVEL=debug
LOG_DIR=logs

# ── File Uploads ─────────────────────────────
MAX_FILE_SIZE=52428800
UPLOAD_DIR=uploads
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif
ALLOWED_VIDEO_TYPES=video/mp4,video/webm,video/quicktime

# ── Socket.IO ────────────────────────────────
SOCKET_CORS_ORIGIN=http://localhost:3000
